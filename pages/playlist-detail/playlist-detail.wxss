/* 歌单详情页样式 */
.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 120rpx;
}

/* 歌单信息区域 */
.playlist-info {
  background: linear-gradient(135deg, #4A90E2 0%, #67B1E7 100%);
  padding: 32rpx;
  color: #ffffff;
}

.playlist-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.pin-icon {
  margin-left: 12rpx;
  font-size: 32rpx;
}

.playlist-description {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.playlist-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  opacity: 0.9;
}

.meta-item {
  margin-right: 24rpx;
  display: flex;
  align-items: center;
}

.meta-icon {
  margin-right: 6rpx;
}

/* 标签区域 */
.tags-section {
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #F5F7FA;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #4E5969;
  margin-bottom: 16rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  cursor: pointer;
}

.tag.active {
  box-shadow: 0 0 0 2rpx currentColor;
}

.add-tag-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  border: 2rpx dashed #C9CDD4;
  color: #86909C;
  margin-bottom: 12rpx;
}

/* 操作栏 */
.action-bar {
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #F5F7FA;
}

.action-count {
  font-size: 28rpx;
  color: #4E5969;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background-color: #4A90E2;
  color: #ffffff;
}

.action-btn.default {
  background-color: #F5F7FA;
  color: #4E5969;
}

/* 歌曲列表 */
.songs-container {
  padding: 24rpx;
}

.songs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.songs-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
}

.songs-count {
  font-size: 24rpx;
  color: #86909C;
  font-weight: 400;
}

/* 歌曲卡片 */
.song-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: flex-start;
}

.song-info {
  flex: 1;
  margin-right: 16rpx;
}

.song-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.favorite-icon {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #FF6B6B;
}

.song-artist {
  font-size: 24rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.song-album {
  font-size: 24rpx;
  color: #A29BFE;
  margin-bottom: 8rpx;
}

.song-mood {
  font-size: 24rpx;
  color: #4A90E2;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.song-tags {
  display: flex;
  flex-wrap: wrap;
}

.song-tag {
  display: inline-block;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.song-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.song-action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #4E5969;
}

.song-action-btn:active {
  background-color: #E8F4FD;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
  color: #86909C;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #C9CDD4;
}

/* 底部添加按钮 */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2 0%, #67B1E7 100%);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ffffff;
  z-index: 100;
}

.fab-button:active {
  transform: scale(0.95);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  max-height: 90vh;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F7FA;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
}

.modal-close {
  font-size: 48rpx;
  color: #86909C;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  border-top: 1rpx solid #F5F7FA;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.confirm {
  background-color: #4A90E2;
  color: #ffffff;
}

.modal-btn.cancel {
  background-color: #F5F7FA;
  color: #4E5969;
}

.modal-btn.delete {
  background-color: #FF6B6B;
  color: #ffffff;
}

/* 输入框样式 */
.input-row {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #4E5969;
  margin-bottom: 12rpx;
  display: block;
}

.input {
  height: 80rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 标签选择器 */
.tags-selector {
  display: flex;
  flex-wrap: wrap;
}

.tag-selector-item {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  cursor: pointer;
  opacity: 0.5;
}

.tag-selector-item.selected {
  opacity: 1;
  box-shadow: 0 0 0 2rpx currentColor;
}