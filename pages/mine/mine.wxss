/* 我的页面样式 */
.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 120rpx;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #4A90E2 0%, #67B1E7 100%);
  padding: 48rpx 32rpx;
  color: #ffffff;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 统计卡片区域 */
.stats-container {
  padding: 24rpx;
  margin-top: -40rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  min-width: 200rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #86909C;
}

/* 功能列表 */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 16rpx;
}

.function-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F7FA;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.function-info {
  flex: 1;
}

.function-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 4rpx;
}

.function-desc {
  font-size: 22rpx;
  color: #86909C;
}

.function-arrow {
  font-size: 28rpx;
  color: #C9CDD4;
}

/* 关于区域 */
.about-section {
  padding: 24rpx;
}

.about-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.about-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.about-version {
  font-size: 24rpx;
  color: #86909C;
  margin-bottom: 24rpx;
}

.about-desc {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.about-features {
  text-align: left;
  font-size: 24rpx;
  color: #4E5969;
  line-height: 1.8;
}

.about-features view {
  margin-bottom: 8rpx;
}

.about-features text {
  color: #4A90E2;
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 48rpx 24rpx;
  font-size: 22rpx;
  color: #C9CDD4;
}
