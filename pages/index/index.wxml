<!-- 首页 - 歌单列表 -->
<view class="page">
  <!-- 加载遮罩 -->
  <view wx:if="{{isLoading}}" class="loading-overlay">
    <view class="loading-spinner">
      <view class="spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info" bindtap="handleUserTap">
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar placeholder">
        <text>👤</text>
      </view>
      <view class="user-details">
        <text wx:if="{{userInfo}}" class="user-name">{{userInfo.nickName}}</text>
        <text wx:else class="user-name">点击登录</text>
        <text class="user-hint">欢迎来到私人歌单整理</text>
      </view>
    </view>
  </view>

  <!-- 顶部区域 -->
  <view class="header">
    <view class="header-title">我的歌单</view>
    <view class="header-subtitle">记录你的音乐心情</view>

    <!-- 搜索栏 -->
    <view class="search-bar">
      <text class="icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索歌单"
        placeholder-style="color: rgba(255, 255, 255, 0.7)"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <!-- 歌单列表 -->
  <view class="playlist-container">
    <!-- 列表标题 -->
    <view class="section-title">
      <text>我的歌单</text>
      <text class="section-count">共 {{playlists.length}} 个</text>
    </view>

    <!-- 歌单卡片列表 -->
    <block wx:if="{{playlists.length > 0}}">
      <view
        wx:for="{{displayedPlaylists}}"
        wx:key="_id"
        class="playlist-card"
        bindtap="goToPlaylistDetail"
        data-id="{{item._id}}"
      >
        <view class="playlist-header">
          <image wx:if="{{item.coverUrl}}" class="playlist-cover" src="{{item.coverUrl}}" mode="aspectFill" />
          <view wx:else class="playlist-cover placeholder">
            <text>🎵</text>
          </view>
          <view class="playlist-info">
            <view class="playlist-name">
              <text>{{item.name}}</text>
              <text wx:if="{{item.isPinned}}" class="pin-icon">📌</text>
            </view>
            <view class="playlist-song-count">{{item.songCount || 0}} 首歌曲</view>
          </view>
        </view>

        <!-- 歌单描述 -->
        <view wx:if="{{item.description}}" class="playlist-description">
          {{item.description}}
        </view>

        <!-- 标签 -->
        <view wx:if="{{item.tags && item.tags.length > 0}}" class="playlist-tags">
          <text
            wx:for="{{item.tags}}"
            wx:for-item="tag"
            wx:key="index"
            class="tag"
            style="background-color: {{tag.color || '#E8F4FD'}}; color: {{tag.color ? '#ffffff' : '#4A90E2'}}"
          >
            {{tag.name}}
          </text>
        </view>

        <!-- 统计信息 -->
        <view class="playlist-meta">
          <view class="playlist-stats">
            <view class="stat-item">
              <text class="stat-icon">📅</text>
              <text>{{item.createTimeFormat}}</text>
            </view>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="playlist-actions" catchtap="noop">
          <view
            class="action-btn {{item.isPinned ? '' : 'primary'}}"
            bindtap="togglePin"
            data-id="{{item._id}}"
          >
            {{item.isPinned ? '取消置顶' : '置顶'}}
          </view>
          <view
            class="action-btn"
            bindtap="editPlaylist"
            data-id="{{item._id}}"
          >
            编辑
          </view>
          <view
            class="action-btn"
            bindtap="deletePlaylist"
            data-id="{{item._id}}"
            data-name="{{item.name}}"
          >
            删除
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:else>
      <view class="empty-state">
        <text class="empty-icon">📋</text>
        <view class="empty-text">还没有歌单</view>
        <view class="empty-hint">点击下方按钮创建第一个歌单吧</view>
      </view>
    </block>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab-button" bindtap="goToAddPlaylist">+</view>

  <!-- 底部导航栏 -->
  <tabbar current-path="/pages/index/index" />
</view>
