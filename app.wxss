/* 全局样式 - 浅蓝简约清新线条风 */

/* 重置样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.h1 {
  font-size: 40rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 16rpx;
}

.h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.h3 {
  font-size: 30rpx;
  font-weight: 500;
  color: #4E5969;
  margin-bottom: 8rpx;
}

/* 文本样式 */
.text-primary {
  color: #4A90E2;
}

.text-secondary {
  color: #86909C;
}

.text-small {
  font-size: 24rpx;
  color: #86909C;
}

/* 按钮样式 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 48rpx;
}

.btn-primary {
  background-color: #4A90E2;
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-default {
  background-color: #ffffff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
}

.btn-default:active {
  background-color: #f0f5ff;
}

/* 输入框样式 */
.input {
  height: 80rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.input-row {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: #4E5969;
  margin-bottom: 12rpx;
}

/* 列表项样式 */
.list-item {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #F5F7FA;
}

.list-item:last-child {
  border-bottom: none;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
  color: #86909C;
}

.empty-state-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 间距工具类 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
